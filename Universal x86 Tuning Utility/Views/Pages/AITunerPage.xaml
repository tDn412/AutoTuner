<Page x:Class="Universal_x86_Tuning_Utility.Views.Pages.AITunerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800"
      Title="AI Smart Auto-Tuner"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tiêu đề trang phong cách Fluent Design -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="AI Smart Auto-Tuner &amp; Benchmark" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
            <TextBlock Text="Hệ thống trí tuệ nhân tạo tự động đo lường đặc tính nhiệt và tối ưu hóa điện năng (TDP) cho chip AMD." 
                       FontSize="14" 
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <!-- CỘT TRÁI: Bảng điều khiển kiểm tra hiệu năng -->
            <ui:Card Grid.Column="0" Margin="0,0,12,0" Padding="20" VerticalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    
                    <!-- Vòng tròn trạng thái chạy Benchmark -->
                    <Grid Width="160" Height="160" Margin="0,0,0,20">
                        <ui:ProgressRing x:Name="BenchmarkProgress" 
                                         IsIndeterminate="False"
                                         Progress="0"
                                         Width="140" Height="140" 
                                         Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ui:SymbolIcon x:Name="StatusIcon" Symbol="Predictions20" FontSize="36" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                            <TextBlock x:Name="ProgressText" Text="Sẵn sàng" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="StatusSubText" 
                               Text="Nhấn nút bắt đầu để chạy Stress-Test 15 giây." 
                               TextAlignment="Center" 
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                               Margin="0,0,0,24"/>

                    <!-- Nút bắt đầu thiết kế rực rỡ -->
                    <ui:Button x:Name="BtnStartTuning" 
                               Content="Bắt đầu AI Auto-Tuning" 
                               Icon="Play24" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Padding="16,12" 
                               Width="240"
                               Appearance="Primary"
                               Click="BtnStartTuning_Click"/>

                    <!-- Thẻ Chế độ Esports bổ sung -->
                    <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Margin="0,20,0,20" Width="260"/>
                    <ui:Card Margin="0,0,0,0" Padding="12" Width="280" HorizontalAlignment="Center">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                <TextBlock Text="Tối ưu Esports (Valorant, LOL)" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="Bật Anti-Lag, mượt hình, hạ trễ chuột tối đa." 
                                           FontSize="10.5" 
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <ui:ToggleSwitch x:Name="TsEsportsMode" Grid.Column="1" VerticalAlignment="Center" IsChecked="True"/>
                        </Grid>
                    </ui:Card>
                </StackPanel>
            </ui:Card>

            <!-- CỘT PHẢI: Bảng kết quả chẩn đoán và cấu hình tối ưu -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Thẻ Kết quả chẩn đoán -->
                <ui:Card Grid.Row="0" Margin="0,0,0,12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="KẾT QUẢ PHÂN TÍCH NHIỆT ĐỘ" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,16"/>
                        
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Nhiệt độ nghỉ (Idle):" FontSize="14"/>
                            <TextBlock x:Name="TxtBaselineTemp" Text="-- °C" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Nhiệt độ đỉnh (Peak):" FontSize="14"/>
                            <TextBlock x:Name="TxtPeakTemp" Text="-- °C" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right" Foreground="#FFFF4D4D"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Tốc độ thoát nhiệt:" FontSize="14"/>
                            <TextBlock x:Name="TxtRiseRate" Text="-- °C/s" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        
                        <Border Height="1" Background="{DynamicResource CardStrokeColorDefaultBrush}" Margin="0,12,0,12"/>
                        
                        <TextBlock Text="Đánh giá hệ thống tản nhiệt:" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtThermalGrade" Text="Chưa có dữ liệu. Vui lòng chạy chẩn đoán." FontSize="14" TextWrapping="Wrap" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" FontWeight="Bold"/>
                    </StackPanel>
                </ui:Card>

                <!-- Thẻ Cấu hình tối ưu đề xuất -->
                <ui:Card Grid.Row="1" Margin="0,0,0,12" Padding="20" VerticalAlignment="Stretch">
                    <StackPanel>
                        <TextBlock Text="CẤU HÌNH TDP &amp; NHIỆT ĐỘ KHUYÊN DÙNG" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,16"/>
                        
                        <ui:InfoBar Title="Mẹo chuyên gia" 
                                    Message="Cấu hình được thiết kế để giữ GPU hoạt động ở 2200MHz tối đa mà không gây quá nhiệt CPU." 
                                    Severity="Informational" 
                                    IsOpen="True" 
                                    Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Giới hạn STAPM Limit (TDP Dài hạn):" FontSize="14"/>
                                <TextBlock x:Name="TxtRecStapm" Text="-- W" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Giới hạn PPT (TDP Ngắn hạn):" FontSize="14"/>
                                <TextBlock x:Name="TxtRecSlowFast" Text="-- W / -- W" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Trần giới hạn nhiệt độ (Temp Limit):" FontSize="14"/>
                                <TextBlock x:Name="TxtRecTempLimit" Text="-- °C" FontSize="18" FontWeight="Bold" Foreground="#FFFF9900"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Hạ thế tối ưu (Curve Optimizer):" FontSize="14"/>
                                <TextBlock x:Name="TxtRecCo" Text="-- (Undervolt)" FontSize="18" FontWeight="Bold" Foreground="#FF33FF33"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Xung nhịp đồ họa tích hợp (iGPU GFX):" FontSize="14"/>
                                <TextBlock x:Name="TxtRecGfxClk" Text="-- MHz" FontSize="18" FontWeight="Bold" Foreground="#FF00FFFF"/>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Dòng điện CPU VRM (TDC / EDC):" FontSize="14"/>
                                <TextBlock x:Name="TxtRecVrm" Text="-- A / -- A" FontSize="18" FontWeight="Bold" Foreground="#FFFF55FF"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <!-- Nút áp dụng nhanh cấu hình tối ưu -->
                <ui:Button x:Name="BtnApplyRec" 
                           Grid.Row="2" 
                           Content="Áp dụng cấu hình tối ưu" 
                           Icon="Checkmark24" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Padding="16,12" 
                           IsEnabled="False"
                           HorizontalAlignment="Stretch" 
                           Appearance="Secondary"
                           Click="BtnApplyRec_Click"/>
            </Grid>
        </Grid>
    </Grid>
</ScrollViewer>
</Page>
